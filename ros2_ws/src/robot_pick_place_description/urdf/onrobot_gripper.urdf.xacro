<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="onrobot_gripper">

  <!--
    Simple visual + movable gripper model
    Assumption:
    - All 3 STL files share the same assembly origin
    - Finger motion is simplified as prismatic sliding
    - We start with X-axis motion; if wrong, we will change axis later
  -->

  <xacro:property name="mesh_path" value="package://robot_pick_place_description/meshes/gripper"/>

  <!-- Adjustable parameters -->
  <xacro:property name="finger_travel" value="0.02"/>   <!-- 2 cm each side -->
  <xacro:property name="base_mass" value="1.0"/>
  <xacro:property name="finger_mass" value="0.2"/>

  <!-- ========================= -->
  <!-- Base link -->
  <!-- ========================= -->
  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/gripper_base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="gray">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.06 0.10"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- ========================= -->
  <!-- Left finger -->
  <!-- ========================= -->
  <link name="left_finger_link">
    <visual>
      <origin xyz="-0.02 -0.03 -0.02" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/left_finger.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0.01 -0.01 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.015 0.04"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="-0.02 -0.03 -0.02" rpy="0 0 0"/>
      <mass value="${finger_mass}"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>

  <!-- ========================= -->
  <!-- Right finger -->
  <!-- ========================= -->
  <link name="right_finger_link">
    <visual>
      <origin xyz="-0.02 0.03 -0.02" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_path}/right_finger.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>

    <collision>
      <origin xyz="0.01 0.01 0.0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.015 0.04"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="-0.02 0.03 -0.02" rpy="0 0 0"/>
      <mass value="${finger_mass}"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0"
               izz="0.0001"/>
    </inertial>
  </link>
  <!-- ========================= -->
  <!-- Finger joints -->
  <!--
    Since all meshes share one assembly frame,
    we start both joints at the base origin.
    Motion is simplified as sliding along Y.
    If motion direction is wrong, we will flip axis later.
  -->
  <!-- ========================= -->

  <!-- Left finger: main actuated joint -->
  <joint name="left_finger_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="left_finger_link"/>
    <origin xyz="0.02 0.03 0.02" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.0" upper="0.0" effort="50" velocity="0.05"/>
  </joint>

  <!-- Right finger: mimics left, but opposite direction -->
  <joint name="right_finger_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="right_finger_link"/>
    <origin xyz="0.02 -0.03 0.02" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="1.0" effort="50" velocity="0.05"/>
    <mimic joint="left_finger_joint" multiplier="-1" offset="0"/>
  </joint>
  <!-- Optional TCP frame -->
  <link name="gripper_tcp"/>

  <joint name="gripper_tcp_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="gripper_tcp"/>
    <origin xyz="0.10 0 0.02" rpy="0 0 0"/>
  </joint>

</robot>
